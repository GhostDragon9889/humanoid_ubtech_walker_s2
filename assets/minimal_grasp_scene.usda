#usda 1.0
(
    defaultPrim = "Root"
    metersPerUnit = 1
    upAxis = "Z"
)

def Xform "Root"
{
}

def DomeLight "WorldLight"
{
    color3f inputs:color = (0.8, 0.85, 1.0)
    float inputs:intensity = 450
}

def DistantLight "KeyLight"
{
    float inputs:angle = 2
    color3f inputs:color = (1.0, 0.95, 0.85)
    float inputs:intensity = 1800
    double3 xformOp:rotateXYZ = (45, 0, 35)
    uniform token[] xformOpOrder = ["xformOp:rotateXYZ"]
}
